digraph UKClearingAdvisor {
  rankdir=LR;
  fontname="Helvetica"; labelloc="t"; fontsize=20;
  label="UK Clearing Advisor - Developer Architecture Reference\naccount REPLACE_ACCOUNT_ID  |  app+data eu-west-2  |  WAF/CloudFront control plane us-east-1";
  node [fontname="Helvetica", fontsize=9, style="filled", shape=box, color="#1F3864", fillcolor="#EAF0FB"];
  edge [fontname="Helvetica", fontsize=8, color="#5b6577"];
  compound=true;

  UKU [label="UK students\n(browser / mobile)", shape=oval, fillcolor="#FFF2CC"];
  ADM [label="Admin / analyst\n(UK or allowed IP)", shape=oval, fillcolor="#FFF2CC"];

  /* ---------- Edge: WAF + CloudFront ---------- */
  subgraph cluster_edge {
    label="Edge  [stacks: waf (us-east-1), cdn (eu-west-2), grafana-front (us-east-1)]";
    style="rounded,filled"; fillcolor="#F4F6F9"; color="#1F3864";
    WAF1 [label="WAF clearing-advisor-webacl  [waf]\nP1 GeoBlock !GB | P2 rate 1000/5min\nP3 BotControl | P4 CommonRuleSet(count)\nP5 KnownBadInputs | P6 SQLi", fillcolor="#FBE5E1"];
    CF1  [label="CloudFront app  [cdn]\nREPLACE_APP_DIST_ID\nREPLACE_APP_CF.cloudfront.net\ngeo whitelist GB | 403->geo-blocked.html", fillcolor="#DDEBF7"];
    WAF2 [label="WAF grafana-webacl  [grafana-front]\ndefault BLOCK\nP1 allow geo GB | P2 allow IPSet\ngrafana-allowed-ips\n(REPLACE_ALLOWED_CIDR, REPLACE_ALLOWED_CIDR_2)", fillcolor="#FBE5E1"];
    CF2  [label="CloudFront Grafana  [grafana-front]\nREPLACE_GRAFANA_DIST_ID\nREPLACE_GRAFANA_CF.cloudfront.net\ntrusted default cert", fillcolor="#DDEBF7"];
  }

  /* ---------- Application (compute + api + data) ---------- */
  subgraph cluster_app {
    label="Application  [stacks: api, compute, data (eu-west-2, serverless)]";
    style="rounded,filled"; fillcolor="#EDEFF4"; color="#1F3864";
    APIGW  [label="API Gateway HTTP API  [api]\nid REPLACE_API_ID  |  stage $default\nPOST /search  GET /subjects /universities\n/scholarships /export /health\nthrottle burst100/rate50 (baseline)\naccess logs 7d\nCORS locked to app CloudFront origin"];
    SC   [label="Lambda SearchCourses  [compute]\nnode22 512MB/10s, X-Ray\nalias 'live' -> latest version\nchecks X-Origin-Verify secret\nrole: SearchCoursesRole", fillcolor="#DDEBF7"];
    GS   [label="Lambda GetSubjects  [compute]\n128MB/5s\nchecks X-Origin-Verify", fillcolor="#DDEBF7"];
    GU   [label="Lambda GetUniversities  [compute]\n256MB/10s\nchecks X-Origin-Verify", fillcolor="#DDEBF7"];
    GSCH [label="Lambda GetScholarships  [compute]\n256MB/10s (GSI SubjectIndex)\nchecks X-Origin-Verify", fillcolor="#DDEBF7"];
    GE   [label="Lambda GenerateExport  [compute]\n1024MB/30s, X-Ray\nzero-dep xlsx+pdf\nchecks X-Origin-Verify", fillcolor="#DDEBF7"];
    HLTH [label="Lambda Health  [compute]\n128MB/5s\nno secret check (external monitors)\nDynamoDB connectivity check", fillcolor="#DDEBF7"];
    DDB  [label="DynamoDB 8 tables  [data]\nUniversityContacts, SubjectDefaults,\nClearingCache, QueryCache, RateLimits,\nChangeLog, CUGRankings, Scholarships\non-demand | TTL | PITR | SSE", shape=box3d, fillcolor="#E4DFEC"];
    EXP  [label="S3 exports  [cdn]\nuk-clearing-advisor-exports-REPLACE_ACCOUNT_ID\n1-day lifecycle", fillcolor="#E2EFDA"];
    S3SITE [label="S3 static site  [cdn]\nuk-clearing-advisor-site-REPLACE_ACCOUNT_ID\nprivate + OAC (vanilla frontend)", fillcolor="#E2EFDA"];
    ART  [label="S3 artifacts\nuk-clearing-advisor-artifacts-REPLACE_ACCOUNT_ID\nLambda zips + provisioning", fillcolor="#E2EFDA"];
  }

  /* ---------- Automation & observability ---------- */
  subgraph cluster_ops {
    label="Automation & observability  [stacks: scaling, observability, compute (eu-west-2)]";
    labelloc="t"; margin=24;
    style="rounded,filled"; fillcolor="#EDEFF4"; color="#1F3864";
    EBS  [label="EventBridge Rules  [scaling/compute]\nScaleUp cron(0 4 13 8 ? 2026)\nScaleDown cron(0 20 13 8 ? 2026)\nDailyScraper cron(0 7 * * ? *)\nResultsDayScraper cron(0/15 4-20 13 8 ? 2026)\nWarmUp cron(0 5 13 8 ? 2026)\nCostReporter cron(0 6 * * ? *)"];
    SCHR [label="EventBridge Scheduler  [compute]\nClearingAdvisor-RampUpScraper\nrate(1 hour) | EndDate 2026-08-12\nreal end date (Scheduler, not cron()) so it\nstops automatically before ResultsDayScraper", fillcolor="#FBE5E1"];
    SCHED [label="Lambda ScheduleManager  [scaling]\nPEAK=100 | UP 400/800 | BASE 50/100", fillcolor="#DDEBF7"];
    DS   [label="Lambda DailyScraper  [compute]\n512MB/300s, global fetch\ntightened open/closed-phrase heuristic\nwrites possibleStatusChange+lastAutomatedCheck", fillcolor="#DDEBF7"];
    WU   [label="Lambda WarmUp  [compute]\ninvokes SearchCourses __WARMUP__", fillcolor="#DDEBF7"];
    CR   [label="Lambda CostReporter  [compute]\n128MB/30s\ntag-filtered ce:GetCostAndUsage\npublishes ClearingAdvisor/DailyCostUSD", fillcolor="#DDEBF7"];
    CW   [label="CloudWatch  [observability]\nns ClearingAdvisor | Logs Insights\n8 alarms (incl. SearchDuration p99) | dashboards:\nOperations, ResultsDay", fillcolor="#FCE4D6"];
    SNS  [label="SNS ClearingAdvisorAlerts  [observability]\nemail: your-email@example.com", fillcolor="#FCE4D6"];
    CE   [label="Cost Explorer (billing API)\nce:GetCostAndUsage\nfilter tag Application=uk-clearing-advisor\n(all 9 stacks tagged; account also runs\nunrelated workloads, so untagged totals\nwould be meaningless)", shape=cds, fillcolor="#FFF2CC"];
  }

  /* ---------- Grafana analytics ---------- */
  subgraph cluster_graf {
    label="Grafana analytics  [stack: grafana (eu-west-2)]";
    style="rounded,filled"; fillcolor="#EDEFF4"; color="#1F3864";
    EC2  [label="EC2 t3.small REPLACE_INSTANCE_ID\nnginx :80 (X-Origin-Verify) -> Grafana :3000\nEIP REPLACE_GRAFANA_EIP | SSM\nSG REPLACE_SG_ID:\n80<-CloudFront PL, 443<-REPLACE_ALLOWED_CIDR", fillcolor="#DAEEF3"];
    COG  [label="Cognito user pool\nREPLACE_USER_POOL_ID\nclient 6025...  (OAuth login)", fillcolor="#FCE1E4"];
    ROLE [label="IAM instance role\nCloudWatchReadOnly + Logs Insights", fillcolor="#FCE1E4"];
    SM   [label="Secrets Manager\nClearingAdvisor-GrafanaAdmin", fillcolor="#FCE1E4"];
  }

  /* ---------- Flows: application ---------- */
  UKU  -> WAF1 [label="HTTPS 443"];
  WAF1 -> CF1  [label="associate", style=dashed, dir=none];
  CF1  -> S3SITE [label="default | CachingOptimized"];
  CF1  -> APIGW  [label="/api/* | CachingDisabled\nApiGeoOriginRequestPolicy (CloudFront-Viewer + device)\nApiRewriteFunction strips /api"];
  APIGW -> SC   [label="POST /search"];
  APIGW -> GS; APIGW -> GU; APIGW -> GSCH; APIGW -> GE; APIGW -> HLTH [label="GET /health"];
  SC   -> DDB  [label="read Contacts/SubjectDefaults/CUG\nrw ClearingCache/QueryCache/RateLimits"];
  GU   -> DDB; GSCH -> DDB; GE -> DDB; HLTH -> DDB [label="GetItem (liveness check)"];
  GE   -> EXP  [label="PutObject + presigned GET (1h)"];
  ART  -> SC   [label="code (S3)", style=dashed, dir=none];

  /* ---------- Flows: automation ---------- */
  EBS   -> SCHED; EBS -> DS; EBS -> WU; EBS -> CR;
  SCHR  -> DS    [label="invoke (hourly, 24 Jul-12 Aug)"];
  SCHED -> SC    [label="PutProvisionedConcurrency(100)"];
  SCHED -> APIGW [label="UpdateStage throttle 400/800"];
  WU    -> SC    [label="warm invoke"];
  DS    -> DDB   [label="scan+update Contacts, write ChangeLog"];
  SC    -> CW    [label="PutMetricData + logs\n(geo, device, UA)"];
  GE -> CW; DS -> CW;
  CR    -> CE    [label="GetCostAndUsage (yesterday, tag-filtered)"];
  CR    -> CW    [label="PutMetricData DailyCostUSD"];
  CW    -> SNS   [label="alarm actions"];

  /* ---------- Flows: grafana ---------- */
  ADM  -> WAF2 [label="HTTPS 443"];
  WAF2 -> CF2  [label="associate", style=dashed, dir=none];
  CF2  -> EC2  [label="HTTP 80 + X-Origin-Verify secret"];
  ADM  -> COG  [label="OAuth redirect", style=dashed];
  EC2  -> COG  [label="generic_oauth"];
  EC2  -> ROLE [dir=none];
  ROLE -> CW   [label="GetMetricData + Logs Insights"];
  SM   -> EC2  [label="admin pw at boot", style=dashed, dir=none];
}
