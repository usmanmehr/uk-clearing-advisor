{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "type": "dashboard",
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts"
      }
    ]
  },
  "editable": true,
  "schemaVersion": 39,
  "title": "UK Clearing Advisor - Access & Geography",
  "tags": [
    "clearing-advisor"
  ],
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "UK visitor map (searches by location)",
      "type": "geomap",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Logs",
          "region": "eu-west-2",
          "logGroupNames": [
            "/aws/lambda/ClearingAdvisor-SearchCourses"
          ],
          "expression": "fields @timestamp, geoLat, geoLon, geoCity, geoRegion | filter ispresent(geoLat) | stats count(*) as requests by geoLat, geoLon, geoCity, geoRegion | sort requests desc",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          }
        }
      ],
      "options": {
        "view": {
          "id": "coords",
          "lat": 54.5,
          "lon": -3.5,
          "zoom": 5
        },
        "basemap": {
          "type": "default",
          "name": "Basemap"
        },
        "layers": [
          {
            "type": "markers",
            "name": "Searches",
            "location": {
              "mode": "coords",
              "latitude": "geoLat",
              "longitude": "geoLon"
            },
            "config": {
              "style": {
                "size": {
                  "field": "requests",
                  "min": 4,
                  "max": 30
                },
                "color": {
                  "field": "requests"
                },
                "opacity": 0.7
              }
            }
          }
        ],
        "tooltip": {
          "mode": "details"
        }
      }
    },
    {
      "id": 2,
      "title": "Requests by UK region",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Logs",
          "region": "eu-west-2",
          "logGroupNames": [
            "/aws/lambda/ClearingAdvisor-SearchCourses"
          ],
          "expression": "fields geoRegion | filter ispresent(geoRegion) | stats count(*) as requests by geoRegion | sort requests desc | limit 15",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-BlPu"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Top cities",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Logs",
          "region": "eu-west-2",
          "logGroupNames": [
            "/aws/lambda/ClearingAdvisor-SearchCourses"
          ],
          "expression": "fields geoCity, geoRegion | filter ispresent(geoCity) | stats count(*) as requests by geoCity, geoRegion | sort requests desc | limit 20",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Searches over time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Metrics",
          "region": "eu-west-2",
          "namespace": "ClearingAdvisor",
          "metricName": "SearchCount",
          "statistic": "Sum",
          "period": "60",
          "matchExact": true,
          "dimensions": {},
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Geo-blocked requests (non-UK) - WAF",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Metrics",
          "region": "us-east-1",
          "namespace": "AWS/WAFV2",
          "metricName": "BlockedRequests",
          "statistic": "Sum",
          "period": "300",
          "dimensions": {
            "WebACL": "clearing-advisor-webacl",
            "Rule": "GeoBlockNonGB",
            "Region": "CloudFront"
          },
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
