      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Metrics",
          "region": "us-east-1",
          "namespace": "AWS/WAFV2",
          "metricName": "BlockedRequests",
          "statistic": "Sum",
          "period": "300",
          "label": "Rate limited",
          "dimensions": {
            "WebACL": "clearing-advisor-webacl",
            "Rule": "RateLimitPerIP",
            "Region": "CloudFront"
          },
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          }
        },
        {
          "refId": "B",
          "queryMode": "Metrics",
          "region": "us-east-1",
          "namespace": "AWS/WAFV2",
          "metricName": "BlockedRequests",
          "statistic": "Sum",
          "period": "300",
          "label": "Bad inputs",
          "dimensions": {
            "WebACL": "clearing-advisor-webacl",
            "Rule": "KnownBadInputs",
            "Region": "CloudFront"
          },
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          }
        }
      ]
    },
